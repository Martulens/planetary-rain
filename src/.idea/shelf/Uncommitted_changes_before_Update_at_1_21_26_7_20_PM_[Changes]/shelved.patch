ew)\n\n# Source Files\nset(SOURCES\n        main.cpp\n        framework.cpp\n        callbacks.cpp\n        game.cpp\n        utilities.cpp\n        camera.cpp\n        draw.cpp\n        debug.cpp\n        context.cpp\n        object.cpp\n        shaderProgram.cpp\n        meshGeometry.cpp\n        modelTexture.cpp\n        sphere.cpp\n        light.cpp\n        scene.cpp\n        skybox.cpp\n        envMap.cpp\n        ui.cpp\n)\n\nset(HEADERS\n        framework.h\n        config.h\n        callbacks.h\n        game.h\n        gamestate.h\n        draw.h\n        camera.h\n        debug.h\n        object.h\n        shaderProgram.h\n        light.h\n        meshGeometry.h\n        modelTexture.h\n        sphere.h\n        context.h\n        utilities.h\n        skybox.h\n        envMap.h\n        ui.h\n)\n\nset(SHADERS\n        shaders/template.vert\n        shaders/template.frag\n)\n\n# Create Executable\nadd_executable(${PROJECT_NAME} ${SOURCES} ${HEADERS} ${SHADERS})\n\n# Include Directories\ntarget_include_directories(${PROJECT_NAME} PRIVATE\n        ${CMAKE_SOURCE_DIR}\n        ${OPENGL_INCLUDE_DIR}\n        ${glew_SOURCE_DIR}/include\n        ${assimp_SOURCE_DIR}/include\n        ${assimp_BINARY_DIR}/include\n        ${stb_SOURCE_DIR}\n)\n\nif (USE_SYSTEM_GLUT)\n    target_include_directories(${PROJECT_NAME} PRIVATE ${FREEGLUT_INCLUDE_DIRS})\nelse ()\n    target_include_directories(${PROJECT_NAME} PRIVATE ${freeglut_SOURCE_DIR}/include)\nendif ()\n\n# Link Libraries\ntarget_link_libraries(${PROJECT_NAME} PRIVATE\n        ${OPENGL_LIBRARIES}\n        glew\n        glm::glm\n        assimp\n        imgui\n)\n\nif (USE_SYSTEM_GLUT)\n    target_link_libraries(${PROJECT_NAME} PRIVATE ${FREEGLUT_LIBRARIES})\nelse ()\n    target_link_libraries(${PROJECT_NAME} PRIVATE freeglut_static)\nendif ()\n\n# Linux-specific libraries\nif (UNIX AND NOT APPLE)\n    target_link_libraries(${PROJECT_NAME} PRIVATE\n            GL\n            GLU\n            m\n            pthread\n