<+>#include \"game.h\"\n#include \"camera.h\"\n#include \"scene.h\"\n\n#include <GL/freeglut_std.h>\n#include <GL/gl.h>\n\n#include \"glm/vec3.hpp\"\n#include \"context.h\"\n#include \"gamestate.h\"\n\n\nvoid restartGame() {\n    glClearColor(skyColorConst.r, skyColorConst.g, skyColorConst.b, 1.0f);\n    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT);\n\n    cleanUpObjects();\n\n    int w = glutGet(GLUT_WINDOW_WIDTH);\n    int h = glutGet(GLUT_WINDOW_HEIGHT);\n\n    if (h == 0) h = 1;\n\n    // Initialize camera - positioned to see all three spheres\n    glm::vec3 camPosition = glm::vec3(0.0f, 4.0f, 12.0f);\n    glm::vec3 direction = glm::vec3(0.0f, -0.2f, -1.0f);\n    float angle = 0.0f;\n\n    Camera* camera = new Camera(w, h, camPosition, direction, angle);\n    GameState* gs = new GameState(w, h);\n    con::init(camera, gs);\n}\n\nvoid cleanUpObjects() {\n    if (con::scene) {\n        delete con::scene;\n        con::scene = nullptr;\n    }\n    if (con::camera) {\n        delete con::camera;\n        con::camera = nullptr;\n    }\n    if (con::gameState) {\n        delete con::gameState;\n        con::gameState = nullptr;\n    }\n}
